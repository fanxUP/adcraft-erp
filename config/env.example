APP_NAME=AdCraft ERP
APP_ENV=production
APP_SECRET_KEY=please_change_this_secret

POSTGRES_DB=adcraft_erp
POSTGRES_USER=adcraft
POSTGRES_PASSWORD=please_change_postgres_password
DATABASE_URL=postgresql+psycopg://adcraft:please_change_postgres_password@postgres:5432/adcraft_erp

REDIS_URL=redis://redis:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=please_change_minio_password
MINIO_BUCKET=adcraft-files

UPLOAD_STORAGE=local
LOCAL_UPLOAD_DIR=/app/uploads

JWT_EXPIRE_MINUTES=1440

LAN_BASE_URL=http://192.168.1.10
