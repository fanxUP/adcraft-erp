# AdCraft ERP — Environment Configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=AdCraft ERP
APP_ENV=development
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_32_byte_hex_string

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=adcraft_erp
POSTGRES_USER=adcraft
POSTGRES_PASSWORD=change_me_in_production
# Local dev: 127.0.0.1  |  Docker: postgres (service name)
DATABASE_URL=postgresql+asyncpg://adcraft:change_me_in_production@127.0.0.1:5432/adcraft_erp
DATABASE_URL_SYNC=postgresql+psycopg2://adcraft:change_me_in_production@127.0.0.1:5432/adcraft_erp

# ── Redis ───────────────────────────────────────────────────────────
# Local dev: 127.0.0.1  |  Docker: redis (service name)
REDIS_URL=redis://127.0.0.1:6379/0

# ── MinIO (Object Storage, optional) ────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_please
MINIO_BUCKET=adcraft-files

# ── Upload ──────────────────────────────────────────────────────────
UPLOAD_STORAGE=local
# Local dev: ./uploads  |  Docker: /app/uploads
LOCAL_UPLOAD_DIR=./uploads

# ── JWT ─────────────────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=1440

# ── AI Features (all optional, disabled by default) ─────────────────
# AI_ENABLED=true
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_API_BASE_URL=
# AI_MODEL=claude-sonnet-4-20250514

# ── LAN Access ──────────────────────────────────────────────────────
LAN_BASE_URL=http://localhost
